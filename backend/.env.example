# TeamHub 生产环境配置
# 复制此文件为 .env 并修改以下值

# JWT 密钥 - 必须修改！使用 openssl rand -base64 48 生成
JWT_SECRET_KEY=change-this-to-a-64-character-random-string-now

# 数据库 - SQLite（生产环境推荐简化方案）
DATABASE_URL=sqlite:///./teamhub.db

# CORS 允许来源 - 填入你的服务器 IP 或域名
# 示例：CORS_ORIGINS=http://123.45.67.89,http://your-domain.com
CORS_ORIGINS=

# 是否允许 seed 接口（生产环境必须设为 false）
ALLOW_SEED=false

# 是否由后端直接服务前端静态文件（Docker + Nginx 场景下不需要）
# SERVE_STATIC=true

# 推送通知 VAPID 密钥（可选）
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
